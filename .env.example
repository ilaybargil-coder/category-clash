# --- Infrastructure ---
DATABASE_URL=postgresql+asyncpg://game:game@localhost:5432/game
CORS_ORIGINS=http://localhost:3000
WEBSOCKET_ORIGINS=http://localhost:3000
WEBSOCKET_ALLOW_MISSING_ORIGIN=true
DATABASE_POOL_SIZE=5
DATABASE_POOL_RECYCLE_SECONDS=300
READINESS_TIMEOUT_SECONDS=3

# --- Auth ---
AUTH_MODE=demo
JWT_SECRET=dev-secret-change-me-at-least-32-bytes
JWT_EXPIRE_MINUTES=720
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_AUTH_TIMEOUT_SECONDS=5
AUTH_IDENTITY_CACHE_SECONDS=300

# --- Gameplay (server-authoritative constants) ---
TURN_SECONDS=15
PREVIEW_SECONDS=4
INTERMISSION_SECONDS=4
ROUNDS_TO_WIN=2
MAX_ANSWER_LENGTH=60
DISCONNECT_FORFEIT_SECONDS=60
WEBSOCKET_SEND_TIMEOUT_SECONDS=2

# --- Phase 2+ ---
INVITE_TTL_SECONDS=90
SWAP_QUESTION_COST_COINS=50
FUZZY_MATCHING_ENABLED=true
FUZZY_MAX_DISTANCE=1
FUZZY_MIN_LENGTH=4

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_AUTH_MODE=demo
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
